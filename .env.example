OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-nano

# Optional. Defaults to ./data/app.sqlite
DATABASE_PATH=./data/app.sqlite

# Playwright browser profile storage. Defaults to ./data/threads-session.json
THREADS_STORAGE_STATE=./data/threads-session.json
THREADS_PROFILE_DIR=./data/threads-browser-profile

# Fetch safety controls
SCRAPER_MAX_POSTS=40
SCRAPER_MIN_DELAY_MS=1500
